   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('students.csv')\n",
    "df['Result'] = df['Marks'].apply(\n",
    "    lambda x : \"Pass\" if x >= 50 else \"Fail\"\n",
    ")\n",
    "df"
   ]
