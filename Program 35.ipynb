   "source": [
    "# Find maximum and minimum sales per region using groupby() and agg()."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "3ac8b812-37c1-40f5-8971-9eef41032de8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "        Sales       \n",
      "          max    min\n",
      "Region              \n",
      "East    48000  20000\n",
      "North   50000  18000\n",
      "South   55000  25000\n",
      "West    52000  15000\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('sales.csv')\n",
    "region_sales = df.groupby('Region').agg({\n",
    "    \"Sales\" : [\"max\", \"min\"]\n",
    "})\n",
    "print(region_sales)"
   ]
  },
