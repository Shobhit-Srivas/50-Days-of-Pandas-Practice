   "source": [
    "# Create a pivot table showing total sales per Region vs Product."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2290835e-c339-4b14-9d34-5c3c1a18fc71",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Product  Laptop  Mobile  Tablet\n",
      "Region                         \n",
      "East      93000       0   20000\n",
      "North     50000   30000   18000\n",
      "South     55000   53000       0\n",
      "West      52000   35000   15000\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('sales.csv')\n",
    "pivot_total = pd.pivot_table(\n",
    "    df,\n",
    "    values = \"Sales\",\n",
    "    index = \"Region\",\n",
    "    columns = \"Product\",\n",
    "    aggfunc = \"sum\",\n",
    "    fill_value = 0\n",
    ")\n",
    "print(pivot_total)"
   ]
  },
