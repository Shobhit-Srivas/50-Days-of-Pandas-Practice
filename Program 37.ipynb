   "metadata": {},
   "source": [
    "# Create a pivot table showing average sales per Region."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "f27b3b77-7350-4297-bcff-d0bad17849ea",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "               Sales\n",
      "Region              \n",
      "East    37666.666667\n",
      "North   32666.666667\n",
      "South   36000.000000\n",
      "West    34000.000000\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('sales.csv')\n",
    "piovt_avg = pd.pivot_table(\n",
    "    df,\n",
    "    values = 'Sales',\n",
    "    index = 'Region',\n",
    "    aggfunc = 'mean'\n",
    ")\n",
    "print(piovt_avg)"
   ]
  },
