   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('students.csv')\n",
    "df['Marks_Normalized'] = (\n",
    "    (df['Marks'] - df['Marks'].min()) /\n",
    "    (df['Marks'].max() - df['Marks'].min())\n",
    ")\n",
    "print(df['Marks_Normalized'])"
   ]
